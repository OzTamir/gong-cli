{
  "name": "@oztamir/gong-cli",
  "version": "0.3.0",
  "description": "Command-line client for the Gong API, built for humans and agents",
  "keywords": [
    "gong",
    "cli",
    "api",
    "revenue-intelligence",
    "sales"
  ],
  "license": "MIT",
  "author": "Oz Tamir",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oztamir/gong-cli.git"
  },
  "type": "module",
  "bin": {
    "gong": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
